---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/paths';
---
<BaseLayout title="Page not found — La Gente de La Tierra" description="The requested page could not be found.">
  <section class="page-hero page-shell">
    <p class="eyebrow">404 · Page not found</p>
    <h1>Take another<br />path.</h1>
    <p class="lead">The page you requested may have moved. Return to the documentary or explore the communities.</p>
    <p><a class="button" href={withBase('/')}>Return home</a> <a class="text-link" href={withBase('/communities/')}>Explore communities ↗</a></p>
  </section>
</BaseLayout>
