---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — La Gente de La Tierra" description="Contact the team behind La Gente de La Tierra.">
  <header class="page-hero page-shell"><p class="eyebrow">Contact</p><h1>Start a<br />conversation.</h1><p class="lead">We welcome inquiries from community organizations, educators, festivals, distributors, journalists, and thoughtful collaborators.</p></header>
  <section class="page-shell contact-grid"><div><h2>Tell us what you have in mind.</h2><p>This form is intentionally inactive in the scaffold. A privacy-conscious form provider and recipient workflow must be selected before launch.</p></div><form aria-label="Contact form preview" onsubmit="return false"><label>Name<input type="text" name="name" autocomplete="name" /></label><label>Email<input type="email" name="email" autocomplete="email" /></label><label>Organization <span>(optional)</span><input type="text" name="organization" autocomplete="organization" /></label><label>Message<textarea name="message" rows="6"></textarea></label><button class="button" type="button" disabled>Form integration pending</button></form></section>
</BaseLayout>
